@startuml PicoGallery – Static Deployment View
!theme plain
skinparam backgroundColor #FAFAFA
skinparam nodeBackgroundColor #E8F5E9
skinparam databaseBackgroundColor #E3F2FD
skinparam componentBackgroundColor #FFFFFF
skinparam ArrowColor #555555
skinparam defaultFontName "Helvetica"

title PicoGallery — Deployment View (Hybrid Split-Drive)

node "Client Device\n(Browser / Mobile App)" as Client {
  component "SPA  web/index.html" as SPA
  component "localStorage\n(pg_token · pg_server)" as LS
  SPA --> LS
}

node "SBC / Linux Server\n(e.g. Radxa Cubie A7S — 8-core, 8 GB RAM)" as Server {

  node "128 GB USB SSD  (fast random I/O)" as SSD {
    database "picogallery.db\n(SQLite WAL)" as DB
    storage "thumbnails/\nblur · small · preview · large" as Thumbs
    storage "tmp/  (upload staging)" as Tmp
  }

  node "1 TB HDD  (sequential I/O, ~120 MB/s)" as HDD {
    storage "originals/\n{userID}/{YYYY}/{MM}/" as Originals
  }

  component "picogallery binary\n(CGO_ENABLED=0, statically linked)" as Binary {
    component "chi Router  :3456" as Router
    component "Auth Service\nJWT · bcrypt · API keys" as Auth
    component "Asset Service\nWorker pool (4 goroutines)" as AssetSvc
    component "Album · Browser · Search\nHandlers" as OtherH
    component "Info Handler\nrescan · stats · jobs" as InfoH
  }

  component "cloudflared\n(Cloudflare Tunnel agent)" as CFd

  Binary --> SSD
  Binary --> HDD
  CFd --> Router : localhost:3456
}

node "Cloudflare Edge\n(Global CDN / Zero Trust)" as CFEdge {
  component "Tunnel endpoint" as CFZT
}

Client  --> CFEdge : HTTPS :443  gallery.example.com
CFEdge --> CFd     : Secure outbound tunnel (QUIC)

note right of SSD
  Fast random I/O needed for:
  • DB metadata queries (gallery scroll)
  • Thumbnail reads (many small JPEGs)
  • Upload staging (fast initial write)
end note

note right of HDD
  Sequential I/O acceptable for:
  • Original photo / video storage
  • Large file reads (download)
end note

note bottom of Binary
  Optional tools on PATH:
  • imagemagick (magick/convert) — HEIC support
  • ffmpeg — video thumbnails (future)
end note

@enduml
